import * as THREE from 'three';
import { BaseEnemy } from './BaseEnemy.js';

export class ShadowForest extends BaseEnemy {
  constructor(scene, position) {
    super(scene, position, {
      name: 'ShadowForest',
      hp: 80,
      maxHp: 80,
      attack: 12,
      defense: 4,
      speed: 0.04,
      detectionRange: 14,
      attackRange: 1.8,
      attackCooldown: 1.8,
      xpReward: 30,
      drops: [
        { item: 'shadow_essence', chance: 0.5 },
        { item: 'dark_wood', chance: 0.3 },
      ]
    });

    this._buildMesh(scene);
  }

  _buildMesh(scene) {
    const group = new THREE.Group();

    // Cuerpo alargado, oscuro
    const bodyGeo = new THREE.CylinderGeometry(0.3, 0.4, 1.4, 6);
    const bodyMat = new THREE.MeshStandardMaterial({ color: 0x1a0a2e });
    const body = new THREE.Mesh(bodyGeo, bodyMat);
    body.position.y = 0.7;
    group.add(body);

    // Cabeza difusa
    const headGeo = new THREE.SphereGeometry(0.35, 6, 6);
    const headMat = new THREE.MeshStandardMaterial({ color: 0x2d0a4e });
    const head = new THREE.Mesh(headGeo, headMat);
    head.position.y = 1.6;
    group.add(head);

    // Ojos brillantes
    const eyeMat = new THREE.MeshStandardMaterial({ color: 0x9900ff, emissive: 0x9900ff, emissiveIntensity: 1 });
    const eyeGeo = new THREE.SphereGeometry(0.07, 4, 4);
    [-0.12, 0.12].forEach(x => {
      const eye = new THREE.Mesh(eyeGeo, eyeMat);
      eye.position.set(x, 1.65, 0.28);
      group.add(eye);
    });

    group.position.copy(position);
    scene.add(group);
    this.mesh = group;
  }

  update(delta, playerPosition) {
    if (this.isDead()) return;
    this._updateAI(delta, playerPosition);

    // Parpadeo de ojos
    const t = performance.now() * 0.003;
    const emissive = 0.6 + Math.sin(t) * 0.4;
    this.mesh.children.forEach(c => {
      if (c.material && c.material.emissiveIntensity !== undefined) {
        c.material.emissiveIntensity = emissive;
      }
    });
  }
}
